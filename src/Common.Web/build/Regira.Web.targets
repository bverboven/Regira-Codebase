<Project>

  <PropertyGroup>
    <_RegiraWebFilesRoot>$(MSBuildThisFileDirectory)..\contentFiles\any\any\ai\</_RegiraWebFilesRoot>
  </PropertyGroup>

  <!--
    Copies Web AI instruction files into the consuming project's
    .github/instructions/regira/ folder on first build.
  -->
  <Target Name="RegiraWebExtractAiFiles"
          BeforeTargets="BeforeBuild"
          Condition="!Exists('$(ProjectDir).github\instructions\regira\web.instructions.md')">

    <MakeDir Directories="$(ProjectDir).github\instructions\regira" />

    <Copy SourceFiles="$(_RegiraWebFilesRoot)web.instructions.md;$(_RegiraWebFilesRoot)web.examples.md"
          DestinationFolder="$(ProjectDir).github\instructions\regira\"
          SkipUnchangedFiles="true" />

  </Target>

</Project>
