<Project>

  <PropertyGroup>
    <_RegiraInvoicingFilesRoot>$(MSBuildThisFileDirectory)..\contentFiles\any\any\ai\</_RegiraInvoicingFilesRoot>
  </PropertyGroup>

  <!--
    Copies Invoicing AI instruction files into the consuming project's
    .github/instructions/regira/ folder on first build.
  -->
  <Target Name="RegiraInvoicingExtractAiFiles"
          BeforeTargets="BeforeBuild"
          Condition="!Exists('$(ProjectDir).github\instructions\regira\invoicing.instructions.md')">

    <MakeDir Directories="$(ProjectDir).github\instructions\regira" />

    <Copy SourceFiles="$(_RegiraInvoicingFilesRoot)invoicing.instructions.md;$(_RegiraInvoicingFilesRoot)invoicing.examples.md"
          DestinationFolder="$(ProjectDir).github\instructions\regira\"
          SkipUnchangedFiles="true" />

  </Target>

</Project>
