<Project>

  <PropertyGroup>
    <_RegiraSystemFilesRoot>$(MSBuildThisFileDirectory)..\contentFiles\any\any\ai\</_RegiraSystemFilesRoot>
  </PropertyGroup>

  <!--
    Copies System AI instruction files into the consuming project's
    .github/instructions/regira/ folder on first build.
  -->
  <Target Name="RegiraSystemExtractAiFiles"
          BeforeTargets="BeforeBuild"
          Condition="!Exists('$(ProjectDir).github\instructions\regira\system.instructions.md')">

    <MakeDir Directories="$(ProjectDir).github\instructions\regira" />

    <Copy SourceFiles="$(_RegiraSystemFilesRoot)system.instructions.md;$(_RegiraSystemFilesRoot)system.examples.md"
          DestinationFolder="$(ProjectDir).github\instructions\regira\"
          SkipUnchangedFiles="true" />

  </Target>

</Project>
