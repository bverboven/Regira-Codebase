<Project>

  <PropertyGroup>
    <_RegiraSetupFilesRoot>$(MSBuildThisFileDirectory)..\ai\</_RegiraSetupFilesRoot>
    <_RegiraBaseDir Condition="'$(SolutionDir)' != '' And '$(SolutionDir)' != '*Undefined*'">$(SolutionDir)</_RegiraBaseDir>
    <_RegiraBaseDir Condition="'$(_RegiraBaseDir)' == ''">$(ProjectDir)</_RegiraBaseDir>
  </PropertyGroup>

  <!--
    Copies shared Regira setup guides into the consuming project's
    .regira/instructions/ folder on first build.
  -->
  <Target Name="RegiraSetupExtractAiFiles"
          BeforeTargets="BeforeBuild"
          Condition="!Exists('$(_RegiraBaseDir).regira\instructions\project.setup.md') Or !Exists('$(_RegiraBaseDir).regira\instructions\shared.setup.md')">

    <MakeDir Directories="$(_RegiraBaseDir).regira\instructions" />

    <Copy SourceFiles="$(_RegiraSetupFilesRoot)project.setup.md;$(_RegiraSetupFilesRoot)shared.setup.md"
          DestinationFolder="$(_RegiraBaseDir).regira\instructions\"
          SkipUnchangedFiles="true" />

  </Target>

  <!--
    Copies Regira slash commands into the consuming project's
    .claude/commands/ folder on first build.
  -->
  <Target Name="RegiraSetupExtractCommandFiles"
          BeforeTargets="BeforeBuild"
          Condition="!Exists('$(_RegiraBaseDir).claude\commands\new-project.md')">

    <MakeDir Directories="$(_RegiraBaseDir).claude\commands" />

    <Copy SourceFiles="$(_RegiraSetupFilesRoot)commands\new-project.md;$(_RegiraSetupFilesRoot)commands\new-entity.md;$(_RegiraSetupFilesRoot)commands\sync-guides.md;$(_RegiraSetupFilesRoot)commands\update-guide.md;$(_RegiraSetupFilesRoot)commands\evaluate.md"
          DestinationFolder="$(_RegiraBaseDir).claude\commands\"
          SkipUnchangedFiles="true" />

  </Target>

</Project>
