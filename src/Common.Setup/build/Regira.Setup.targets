<Project>

  <PropertyGroup>
    <_RegiraSetupFilesRoot>$(MSBuildThisFileDirectory)..\contentFiles\any\any\ai\</_RegiraSetupFilesRoot>
  </PropertyGroup>

  <!--
    Copies shared Regira setup guides into the consuming project's
    .github/instructions/regira/ folder on first build.
  -->
  <Target Name="RegiraSetupExtractAiFiles"
          BeforeTargets="BeforeBuild"
          Condition="!Exists('$(ProjectDir).github\instructions\regira\project.setup.md') Or !Exists('$(ProjectDir).github\instructions\regira\shared.setup.md')">

    <MakeDir Directories="$(ProjectDir).github\instructions\regira" />

    <Copy SourceFiles="$(_RegiraSetupFilesRoot)project.setup.md;$(_RegiraSetupFilesRoot)shared.setup.md"
          DestinationFolder="$(ProjectDir).github\instructions\regira\"
          SkipUnchangedFiles="true" />

  </Target>

  <!--
    Copies Regira slash commands into the consuming project's
    .claude/commands/ folder on first build.
  -->
  <Target Name="RegiraSetupExtractCommandFiles"
          BeforeTargets="BeforeBuild"
          Condition="!Exists('$(ProjectDir).claude\commands\new-project.md')">

    <MakeDir Directories="$(ProjectDir).claude\commands" />

    <Copy SourceFiles="$(_RegiraSetupFilesRoot)commands\new-project.md;$(_RegiraSetupFilesRoot)commands\new-entity.md;$(_RegiraSetupFilesRoot)commands\sync-guides.md;$(_RegiraSetupFilesRoot)commands\update-guide.md;$(_RegiraSetupFilesRoot)commands\evaluate.md"
          DestinationFolder="$(ProjectDir).claude\commands\"
          SkipUnchangedFiles="true" />

  </Target>

</Project>