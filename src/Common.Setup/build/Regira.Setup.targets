<Project>

  <PropertyGroup>
    <_RegiraSetupFilesRoot>$(MSBuildThisFileDirectory)..\files\</_RegiraSetupFilesRoot>
  </PropertyGroup>

  <!--
    Runs once: copies the setup instruction file, manifest template, and sync scripts
    into the consuming project's directory. Skipped on subsequent builds.
  -->
  <Target Name="RegiraSetupExtractFiles"
          BeforeTargets="BeforeBuild"
          Condition="!Exists('$(ProjectDir)ai\regira.setup.instructions.md')">

    <MakeDir Directories="$(ProjectDir).github;$(ProjectDir)ai;$(ProjectDir)tools\ai" />

    <Copy SourceFiles="$(_RegiraSetupFilesRoot)ai\regira.setup.instructions.md"
          DestinationFolder="$(ProjectDir)ai\" />

    <Copy SourceFiles="$(_RegiraSetupFilesRoot)regira.modules.template.json"
          DestinationFolder="$(ProjectDir)\" />

    <Copy SourceFiles="$(_RegiraSetupFilesRoot)tools\ai\sync-consumer-instructions.ps1;$(_RegiraSetupFilesRoot)tools\ai\sync-consumer-instructions.sh"
          DestinationFolder="$(ProjectDir)tools\ai\" />

    <Copy SourceFiles="$(_RegiraSetupFilesRoot)copilot-instructions.starter.md"
          DestinationFiles="$(ProjectDir).github\copilot-instructions.md"
          Condition="!Exists('$(ProjectDir).github\copilot-instructions.md')" />

    <Copy SourceFiles="$(_RegiraSetupFilesRoot)copilot-instructions.starter.md"
          DestinationFiles="$(ProjectDir)AGENTS.md"
          Condition="!Exists('$(ProjectDir)AGENTS.md')" />

    <Message Text="------------------------------------------------------------" Importance="High" />
    <Message Text="Regira.Setup: files extracted to your project directory." Importance="High" />
    <Message Text="Ask your AI agent to read ai/regira.setup.instructions.md" Importance="High" />
    <Message Text="------------------------------------------------------------" Importance="High" />

  </Target>

</Project>
