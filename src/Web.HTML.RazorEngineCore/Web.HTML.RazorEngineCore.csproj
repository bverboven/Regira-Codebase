<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <Authors>B.Verboven</Authors>
    <RootNamespace>Regira.Web.HTML.RazorEngineCore</RootNamespace>
    <PackageId>Regira.Web.HTML.RazorEngineCore</PackageId>
    <AssemblyName>Regira.Web.HTML.RazorEngineCore</AssemblyName>
