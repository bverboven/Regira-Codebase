<Project>

  <PropertyGroup>
    <_RegiraEntitiesFilesRoot>$(MSBuildThisFileDirectory)..\ai\</_RegiraEntitiesFilesRoot>
    <_RegiraBaseDir Condition="'$(SolutionDir)' != '' And '$(SolutionDir)' != '*Undefined*'">$(SolutionDir)</_RegiraBaseDir>
    <_RegiraBaseDir Condition="'$(_RegiraBaseDir)' == ''">$(ProjectDir)</_RegiraBaseDir>
  </PropertyGroup>

  <!--
    Copies Entities AI instruction files into the consuming project's
    .regira/instructions/ folder on first build.
  -->
  <Target Name="RegiraEntitiesExtractAiFiles"
          BeforeTargets="BeforeBuild"
          Condition="!Exists('$(_RegiraBaseDir).regira\instructions\entities.instructions.md')">

    <MakeDir Directories="$(_RegiraBaseDir).regira\instructions" />

    <Copy SourceFiles="$(_RegiraEntitiesFilesRoot)entities.instructions.md;$(_RegiraEntitiesFilesRoot)entities.setup.md;$(_RegiraEntitiesFilesRoot)entities.examples.md;$(_RegiraEntitiesFilesRoot)entities.signatures.md;$(_RegiraEntitiesFilesRoot)entities.namespaces.md;$(_RegiraEntitiesFilesRoot)entities.advanced.example.md"
          DestinationFolder="$(_RegiraBaseDir).regira\instructions\"
          SkipUnchangedFiles="true" />

  </Target>

  <!--
    Copies the Entities subagent prompt into the consuming project's
    .claude/agents/ folder on first build.
  -->
  <Target Name="RegiraEntitiesExtractAgentFiles"
          BeforeTargets="BeforeBuild"
          Condition="!Exists('$(_RegiraBaseDir).claude\agents\entities-agent.md')">

    <MakeDir Directories="$(_RegiraBaseDir).claude\agents" />

    <Copy SourceFiles="$(_RegiraEntitiesFilesRoot)entities-agent.md"
          DestinationFolder="$(_RegiraBaseDir).claude\agents\"
          SkipUnchangedFiles="true" />

  </Target>

</Project>
