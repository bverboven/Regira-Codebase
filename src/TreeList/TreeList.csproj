<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;net8.0;net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <Authors>B.Verboven</Authors>
    <RootNamespace>Regira.TreeList</RootNamespace>
    <PackageId>Regira.TreeList</PackageId>
    <AssemblyName>Regira.TreeList</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>1701;1702;1591</NoWarn>
    <Version>5.4.1</Version>
  
    <Description>Hierarchical tree list data structure and LINQ extensions for Regira.</Description>
    <PackageTags>regira;treelist;tree;hierarchy;linq</PackageTags>
</PropertyGroup>
  <!-- MSBuild targets — auto-imported into consuming builds via NuGet buildTransitive -->
  <ItemGroup>
    <None Include="build\Regira.TreeList.props" Pack="true" PackagePath="buildTransitive\" />
    <None Include="build\Regira.TreeList.targets" Pack="true" PackagePath="buildTransitive\" />
  </ItemGroup>
  <!-- AI instruction files -->
  <ItemGroup>
    <None Include="ai\treelist.instructions.md" Pack="true" PackagePath="ai\" />
    <None Include="ai\treelist.examples.md" Pack="true" PackagePath="ai\" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Common\Common.csproj" />
  </ItemGroup>
</Project>