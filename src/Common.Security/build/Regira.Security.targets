<Project>

  <PropertyGroup>
    <_RegiraSecurityFilesRoot>$(MSBuildThisFileDirectory)..\contentFiles\any\any\ai\</_RegiraSecurityFilesRoot>
  </PropertyGroup>

  <!--
    Copies Security AI instruction files into the consuming project's
    .github/instructions/regira/ folder on first build.
  -->
  <Target Name="RegiraSecurityExtractAiFiles"
          BeforeTargets="BeforeBuild"
          Condition="!Exists('$(ProjectDir).github\instructions\regira\security.instructions.md')">

    <MakeDir Directories="$(ProjectDir).github\instructions\regira" />

    <Copy SourceFiles="$(_RegiraSecurityFilesRoot)security.instructions.md;$(_RegiraSecurityFilesRoot)security.examples.md"
          DestinationFolder="$(ProjectDir).github\instructions\regira\"
          SkipUnchangedFiles="true" />

  </Target>

</Project>
